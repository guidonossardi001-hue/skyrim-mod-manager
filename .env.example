# ── Nexus Mods integration (DEFERRED ACTIVATION) ─────────────────────────────
# The app is fully functional WITHOUT Nexus (a mock provider serves offline data).
# Leave NEXUS_ENABLED=false until a real API key is available. When you set the key
# and NEXUS_ENABLED=true, the HTTP provider activates automatically — no code change.
#
# SECURITY: never commit a real key. In production prefer the OS-encrypted settings
# store (safeStorage) over this file; this .env is for local/CI only.
NEXUS_API_KEY=
NEXUS_ENABLED=false

# ── Delta manifest signing ───────────────────────────────────────────────────
# Optional override of the pinned Ed25519 public key (PEM). Used for key rotation
# without a rebuild. The matching PRIVATE key lives only in the CI secret store.
# NOLVUS_MANIFEST_PUBKEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
