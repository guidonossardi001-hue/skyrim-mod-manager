{
  "name": "skyrim-ae-mod-manager",
  "version": "1.0.8",
  "description": "Skyrim AE Fantasy Launcher - avvio One-Click della versione moddata",
  "author": "Skyrim AE Fantasy Launcher",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --config vite.browser.config.ts",
    "build": "tsc && vite build",
    "electron:dev": "vite",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src electron scripts",
    "lint:fix": "eslint src electron scripts --fix",
    "format": "prettier --write src electron scripts",
    "format:check": "prettier --check src electron scripts",
    "icon:placeholder": "node scripts/make_placeholder_icon.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@nexusmods/fomod-installer-native": "^0.13.3",
    "7zip-bin": "^5.2.0",
    "adm-zip": "^0.5.10",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "js-yaml": "^5.2.1",
    "lucide-react": "^0.344.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-virtuoso": "^4.7.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.17",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "postcss": "^8.4.35",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.skyrim.ae-mod-manager",
    "productName": "Skyrim AE Mod Manager",
    "copyright": "Copyright © 2026 Skyrim AE Fantasy Launcher",
    "asar": true,
    "protocols": [
      {
        "name": "Nexus Mods Download Link",
        "schemes": [
          "nxm"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@nexusmods/fomod-installer-native/**"
    ],
    "extraResources": [
      {
        "from": "resources/7zip-full",
        "to": "7zip-full"
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*.ico"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "guidonossardi001-hue",
        "repo": "skyrim-mod-manager"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/dragon_launcher.ico",
      "signAndEditExecutable": false,
      "artifactName": "Skyrim-AE-Fantasy-Launcher-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Skyrim AE Fantasy Launcher",
      "installerIcon": "assets/dragon_launcher.ico",
      "uninstallerIcon": "assets/dragon_launcher.ico",
      "installerHeaderIcon": "assets/dragon_launcher.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "disableAsarIntegrity": true,
    "npmRebuild": false
  }
}
