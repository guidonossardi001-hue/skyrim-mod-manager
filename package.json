{
  "name": "skyrim-ae-mod-manager",
  "version": "1.0.0",
  "description": "Skyrim AE Mod Manager - Anime Fantasy Edition",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --config vite.browser.config.ts",
    "build": "tsc && vite build",
    "electron:dev": "vite",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src electron scripts",
    "lint:fix": "eslint src electron scripts --fix",
    "format": "prettier --write src electron scripts",
    "format:check": "prettier --check src electron scripts",
    "icon:placeholder": "node scripts/make_placeholder_icon.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "7zip-bin": "^5.2.0",
    "adm-zip": "^0.5.10",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.3.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "electron-store": "^8.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-virtuoso": "^4.7.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^24.13.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "postcss": "^8.4.35",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^1.6.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.skyrim.ae-mod-manager",
    "productName": "Skyrim AE Mod Manager",
    "asar": true,
    "protocols": [
      {
        "name": "Nexus Mods Download Link",
        "schemes": [
          "nxm"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/7zip-bin/**"
    ],
    "extraResources": [
      {
        "from": "resources/7zip-full",
        "to": "7zip-full"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
